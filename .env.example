# Headless auth for the memory compiler (flush.py / backfill.py / compile.py).
#
# The desktop app uses host-managed OAuth that subprocess-spawned claude CLIs
# cannot see, so background flush/compile need their own long-lived token.
#
# 1. Run:  claude setup-token   (opens a browser; requires Pro/Max)
# 2. Copy the printed  sk-ant-oat01-...  value
# 3. Save this file as  .env  (NOT .env.example) with the value below filled in
#
# .env is gitignored. Never commit the real token; never paste it into a chat.

CLAUDE_CODE_OAUTH_TOKEN=
